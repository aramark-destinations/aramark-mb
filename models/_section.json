          "options": [
            {
              "name": "None",
              "value": ""
            },
            {
              "name": "Darken - 20%",
              "value": "darken-20"
            },
            {
              "name": "Darken - 40%",
              "value": "darken-40"
            },
            {
              "name": "Lighten - 20%",
              "value": "lighten-20"
            },
            {
              "name": "Lighten - 40%",
              "value": "lighten-40"
            }
          ]
        },
        {
          "component": "select",
          "name": "linearGradient",
          "label": "Linear Gradient",
          "options": [
            {
              "name": "None",
              "value": ""
            },
            {
              "name": "Bottom to Top",
              "value": "bottom-to-top"
            },
            {
              "name": "Top to Bottom",
              "value": "top-to-bottom"
            },
            {
              "name": "Left to Right",
              "value": "left-to-right"
            },
            {
              "name": "Right to Left",
              "value": "right-to-left"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "number",
          "name": "gradientStartOpacity",
          "label": "Starting Opacity",
          "description": "Gradient starting opacity (0-100)",
          "value": ""
        },
        {
          "component": "text",
          "valueType": "number",
          "name": "gradientEndOpacity",
          "label": "Ending Opacity",
          "description": "Gradient ending opacity (0-100)",
          "value": ""
        },
        {
          "component": "select",
          "name": "sectionTheme",
          "label": "Section Theme Style",
