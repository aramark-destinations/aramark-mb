{
  "definitions": [
    {
      "title": "Section",
      "id": "section",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/section/v1/section",
            "template": {
              "model": "section"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "section",
      "fields": [
        {
          "component": "text",
          "name": "name",
          "label": "Section Name",
          "description": "The label shown for this section in the Content Tree"
        },
        {
          "component": "select",
          "name": "sectionType",
          "label": "Section Type",
          "description": "Controls the width of the Section and the content inside the Section",
          "options": [
            {
              "name": "Full-width",
              "value": "full-width"
            },
            {
              "name": "Contained",
              "value": "contained"
            },
            {
              "name": "Full-Bleed",
              "value": "full-bleed"
            }
          ]
        },
        {
          "component": "reference",
          "name": "backgroundImage",
          "label": "Background Image",
          "multi": false
        },
        {
          "component": "text",
          "name": "backgroundAlt",
          "label": "Background Alt",
          "description": "Alt text for background image"
        },
        {
          "component": "select",
          "name": "backgroundColor",
          "label": "Background Color",
          "options": [
            {
              "name": "Dark",
              "value": "dark"
            },
            {
              "name": "Light",
              "value": "light"
            },
            {
              "name": "Light 2",
              "value": "light-2"
            },
            {
              "name": "Brand",
              "value": "brand"
            },
            {
              "name": "Tertiary",
              "value": "tertiary"
            }
          ]
        },
        {
          "component": "select",
          "name": "fullOverlay",
          "label": "Full Overlay",
