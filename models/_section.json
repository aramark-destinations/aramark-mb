          "options": [
            {
              "name": "Dark",
              "value": "theme-dark"
            },
            {
              "name": "Light",
              "value": "theme-light"
            },
            {
              "name": "Light 2",
              "value": "theme-light-2"
            },
            {
              "name": "Brand",
              "value": "theme-brand"
            },
            {
              "name": "Tertiary",
              "value": "theme-tertiary"
            }
          ]
        },
        {
          "component": "multiselect",
          "name": "style",
          "label": "Style",
          "options": [
            {
              "name": "Highlight",
              "value": "highlight"
            }
          ]
        }
